{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "$ref": "#/definitions/Welcome7",
  "definitions": {
    "Welcome7": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "processingDate": {
          "type": "string",
          "format": "date-time"
        },
        "transactionDetails": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TransactionDetail"
          }
        }
      },
      "required": [
        "processingDate",
        "transactionDetails"
      ],
      "title": "Welcome7"
    },
    "TransactionDetail": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "transactionType": {
          "$ref": "#/definitions/TransactionType"
        },
        "transactionDesc": {
          "type": "string"
        },
        "transactionDate": {
          "type": "string",
          "format": "date"
        },
        "originalAmount": {
          "type": "integer"
        },
        "outstandingAmount": {
          "type": "integer"
        },
        "clearedAmount": {
          "type": "integer"
        },
        "clearingDetails": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ClearingDetail"
          }
        },
        "startDate": {
          "type": "string",
          "format": "date"
        },
        "endDate": {
          "type": "string",
          "format": "date"
        },
        "chargeRefNo": {
          "type": "string"
        },
        "dueDate": {
          "type": "string",
          "format": "date"
        },
        "accruedInterest": {
          "type": "integer"
        },
        "standOverAmount": {
          "type": "integer"
        },
        "appealFlag": {
          "type": "boolean"
        }
      },
      "required": [
        "originalAmount",
        "transactionDate",
        "transactionDesc",
        "transactionType"
      ],
      "title": "TransactionDetail"
    },
    "ClearingDetail": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "transactionDesc": {
          "type": "string"
        },
        "chargeRefNo": {
          "type": "string"
        },
        "dueDate": {
          "type": "string",
          "format": "date"
        },
        "amount": {
          "type": "integer"
        },
        "clearingDate": {
          "type": "string",
          "format": "date"
        },
        "clearingReason": {
          "$ref": "#/definitions/ClearingReason"
        }
      },
      "required": [
        "amount",
        "clearingDate",
        "clearingReason",
        "transactionDesc"
      ],
      "title": "ClearingDetail"
    },
    "ClearingReason": {
      "type": "string",
      "enum": [
        "Allocated to Charge",
        "Outgoing payment - Paid",
        "Cleared by Payment"
      ],
      "title": "ClearingReason"
    },
    "TransactionType": {
      "type": "string",
      "enum": [
        "PAYMENT",
        "CREDIT",
        "DEBIT"
      ],
      "title": "TransactionType"
    }
  }
}
